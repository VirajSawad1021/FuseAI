# Copy this file to .env and fill in your actual values
# cp .env.example .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=assignment_db

# Async URL for SQLAlchemy (used by /customers/* routes)
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/assignment_db

# Sync URL override for psycopg2 (used by /agent/sql — optional, auto-built from above)
# DATABASE_URL_SYNC=postgresql://postgres:your_password_here@localhost:5432/assignment_db

# OpenAI API key — required for /agent/sql
OPENAI_API_KEY=sk-your-key-here
